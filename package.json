{
  "name": "lora-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:dev": "node --watch backend/server.mjs",
    "backend:start": "node backend/server.mjs",
    "seo:validate": "tsx scripts/validate-seo.ts",
    "seo:sitemap": "tsx scripts/generate-sitemap.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint-staged": "lint-staged",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "build": "npm run seo:validate && npm run seo:sitemap && vite build && vite build --ssr src/entry-server.tsx --outDir dist/server --emptyOutDir false && node scripts/prerender.mjs",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "motion": "12.23.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.1.12",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "tailwindcss": "4.1.12",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,mjs,json,css,md,html}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "vite": "6.4.3"
    }
  }
}
